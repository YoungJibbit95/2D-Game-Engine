  "assetConventions": {
    "playerParts": "All player customization sheets are transparent 16x32 frames. Keep head, torso, arms, legs, and feet in the same rig positions as entities/player/base_actions. Variant sheets may add frames but should not change frame size.",
    "hair": "Hair variants should cover the head area only, with optional pixels behind the neck for long styles. Avoid covering the whole face unless the frame is explicitly a hood or cap hair style.",
    "clothes": "Clothing variants should include coordinated shirt and pants colors with simple highlights. Preserve readable arms and legs for compositing.",
    "accessories": "Accessory and hat frames should sit on top of the base rig and remain sparse enough to combine with hair/body layers.",
    "entities": "Rabbit, bird, bat, and cave worm sheets are 64x16, four frames, 16x16 each. Use larger silhouettes and clear motion poses."
  }
